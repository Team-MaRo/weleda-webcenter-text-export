{
  "extends": "@iwf-web/tsconfig/react-strict/tsconfig.json",
  "include": [
    "**/*",
    "**/.server/**/*",
    "**/.client/**/*",
    ".react-router/types/**/*",
    "worker-configuration.d.ts",
    "workers/**/*"
  ],
  "compilerOptions": {
    "types": ["node", "vite/client"],
    "rootDirs": [".", "./.react-router/types"],
    "paths": {
      "~/*": ["./app/*"]
    },
    "resolveJsonModule": true,
    "allowJs": true
  }
}
