# Node
node_modules/
*.log
.npm
.pnpm-store/

# Build artifacts
build/
.react-router/

# Vite dep-optimizer cache. Vite usually writes this under node_modules/.vite/
# (already ignored via node_modules/), but editor integrations like
# Console Ninja shift cacheDir back to the project root.
.vite/

# Nix build outputs — host-specific symlinks into /nix/store, never useful to commit.
result
result-*
image.tar

# Env
.env
.env.local
.env.*.local

.claude/settings.local.json
CLAUDE.md

# Vagrant — runtime state and user-customised copies of the .dist templates.
# The .dist files themselves remain committed.
.vagrant/
.vagrant.config.yml
compose.vm.yml

# mkcert-generated certs (regenerated locally on `vagrant up`)
.docker/certs/cert.pem
.docker/certs/key.pem
