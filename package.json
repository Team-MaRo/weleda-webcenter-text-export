  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "react-router build",
    "build:cf": "CLOUDFLARE=true nr build",
    "dev": "react-router dev",
    "dev:cf": "CLOUDFLARE=true nr dev",
    "deploy:cf": "nr build:cf && wrangler deploy",
    "cf-typegen": "wrangler types",
    "start": "react-router-serve ./build/server/index.js",
    "preview": "vite preview --outDir build/client",
    "typecheck": "nr cf-typegen && react-router typegen && tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
